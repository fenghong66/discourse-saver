{
  "manifest_version": 3,
  "name": "LinuxDo to Obsidian",
  "version": "3.5.8",
  "description": "一键保存LinuxDo帖子+评论到Obsidian或飞书多维表格（支持双保存）",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://open.feishu.cn/*",
    "https://open.larksuite.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://linux.do/*"],
      "js": ["lib/turndown.min.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
